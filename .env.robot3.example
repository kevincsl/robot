
TELEAPP_TOKEN=<your telegram bot token for robot 3>
TELEAPP_ALLOWED_USER_ID=<your telegram user id>
TELEAPP_APP=robot.py

# Robot Identity
ROBOT_ID=robot-3

# Default Provider & Model
ROBOT_DEFAULT_PROVIDER=gemini
ROBOT_DEFAULT_MODEL=gemini-2.5-pro

# Provider Commands & Settings
ROBOT_CODEX_CMD=codex
ROBOT_CODEX_BYPASS_APPROVALS_AND_SANDBOX=0
ROBOT_CODEX_SKIP_GIT_REPO_CHECK=0

ROBOT_CLAUDE_CMD=claude
ROBOT_CLAUDE_SKIP_PERMISSIONS=0
ROBOT_CLAUDE_MODEL_FLAG=--model

ROBOT_GEMINI_CMD=gemini
ROBOT_GEMINI_MODEL_FLAG=--model

# Custom Models (comma-separated)
ROBOT_CUSTOM_MODELS=gemini-2.5-flash,gemini-exp

# API URLs (if using custom endpoints)
# ROBOT_CODEX_API_URL=https://api.openai.com/v1
# ROBOT_CLAUDE_API_URL=https://api.anthropic.com
# ROBOT_GEMINI_API_URL=https://generativelanguage.googleapis.com

# API Keys (if needed)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...

# Auto Dev Agent
ROBOT_AUTO_DEV_CMD=python auto_dev_agent.py

# Projects & State
ROBOT_PROJECTS_ROOTS=
ROBOT_STATE_HOME=

# Google Calendar Integration
ROBOT_GOOGLE_CALENDAR_ENABLED=0
ROBOT_GOOGLE_CALENDAR_CREDENTIALS_PATH=
ROBOT_GOOGLE_CALENDAR_TOKEN_PATH=
ROBOT_GOOGLE_CALENDAR_ID=primary
ROBOT_GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.readonly
